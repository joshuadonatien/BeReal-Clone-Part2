<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24506" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24504"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <tableViewCell contentMode="scaleToFill" selectionStyle="none" indentationWidth="10" reuseIdentifier="PostCell" id="cel-00-001" customClass="PostCell" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="393" height="420"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <tableViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" tableViewCell="cel-00-001" id="cv-000-001">
                <rect key="frame" x="0.0" y="0.0" width="393" height="420"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <!--Post Image View-->
                    <imageView opaque="NO" clipsSubviews="YES" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="piv-000-001">
                        <rect key="frame" x="12" y="12" width="369" height="280"/>
                        <constraints>
                            <constraint firstAttribute="height" constant="280" id="piv-h-001"/>
                        </constraints>
                    </imageView>
                    <!--Blur View (overlay on image, hidden by default)-->
                    <visualEffectView hidden="YES" opaque="NO" contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="blur-view-001">
                        <rect key="frame" x="12" y="12" width="369" height="280"/>
                        <blurEffect style="regular"/>
                    </visualEffectView>
                    <!--Username Label-->
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Username" textAlignment="natural" lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="lbl-usr-001">
                        <rect key="frame" x="12" y="304" width="180" height="20"/>
                        <fontDescription key="fontDescription" type="system" pointSize="16"/>
                        <nil key="textColor"/>
                        <nil key="highlightedColor"/>
                    </label>
                    <!--Timestamp Label-->
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="2h ago" textAlignment="right" lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="lbl-ts-001">
                        <rect key="frame" x="281" y="304" width="100" height="20"/>
                        <fontDescription key="fontDescription" type="system" pointSize="12"/>
                        <nil key="textColor"/>
                        <nil key="highlightedColor"/>
                    </label>
                    <!--Caption Label-->
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Caption goes here" textAlignment="natural" lineBreakMode="wordWrap" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="lbl-cap-001">
                        <rect key="frame" x="12" y="332" width="369" height="20"/>
                        <fontDescription key="fontDescription" type="system" pointSize="14"/>
                        <nil key="textColor"/>
                        <nil key="highlightedColor"/>
                    </label>
                    <!--Location Label (hidden by default)-->
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Location" textAlignment="natural" lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" hidden="YES" translatesAutoresizingMaskIntoConstraints="NO" id="lbl-loc-001">
                        <rect key="frame" x="12" y="360" width="369" height="16"/>
                        <fontDescription key="fontDescription" type="system" pointSize="12"/>
                        <nil key="textColor"/>
                        <nil key="highlightedColor"/>
                    </label>
                    <!--Comments Button-->
                    <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="left" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="cmt-btn-001">
                        <rect key="frame" x="12" y="380" width="140" height="30"/>
                        <constraints>
                            <constraint firstAttribute="height" constant="30" id="cmt-btn-h-001"/>
                        </constraints>
                        <state key="normal" title="💬 Comments"/>
                    </button>
                </subviews>
                <constraints>
                    <!--Image View-->
                    <constraint firstItem="piv-000-001" firstAttribute="top" secondItem="cv-000-001" secondAttribute="top" constant="12" id="piv-top-001"/>
                    <constraint firstItem="piv-000-001" firstAttribute="leading" secondItem="cv-000-001" secondAttribute="leading" constant="12" id="piv-lead-001"/>
                    <constraint firstItem="cv-000-001" firstAttribute="trailing" secondItem="piv-000-001" secondAttribute="trailing" constant="12" id="piv-trail-001"/>
                    <!--Blur View pinned over imageView-->
                    <constraint firstItem="blur-view-001" firstAttribute="top" secondItem="piv-000-001" secondAttribute="top" id="blur-top-001"/>
                    <constraint firstItem="blur-view-001" firstAttribute="leading" secondItem="piv-000-001" secondAttribute="leading" id="blur-lead-001"/>
                    <constraint firstItem="blur-view-001" firstAttribute="trailing" secondItem="piv-000-001" secondAttribute="trailing" id="blur-trail-001"/>
                    <constraint firstItem="blur-view-001" firstAttribute="bottom" secondItem="piv-000-001" secondAttribute="bottom" id="blur-bot-001"/>
                    <!--Username Label-->
                    <constraint firstItem="lbl-usr-001" firstAttribute="top" secondItem="piv-000-001" secondAttribute="bottom" constant="12" id="usr-top-001"/>
                    <constraint firstItem="lbl-usr-001" firstAttribute="leading" secondItem="cv-000-001" secondAttribute="leading" constant="12" id="usr-lead-001"/>
                    <!--Timestamp Label-->
                    <constraint firstItem="lbl-ts-001" firstAttribute="centerY" secondItem="lbl-usr-001" secondAttribute="centerY" id="ts-cy-001"/>
                    <constraint firstItem="cv-000-001" firstAttribute="trailing" secondItem="lbl-ts-001" secondAttribute="trailing" constant="12" id="ts-trail-001"/>
                    <!--Caption Label-->
                    <constraint firstItem="lbl-cap-001" firstAttribute="top" secondItem="lbl-usr-001" secondAttribute="bottom" constant="6" id="cap-top-001"/>
                    <constraint firstItem="lbl-cap-001" firstAttribute="leading" secondItem="cv-000-001" secondAttribute="leading" constant="12" id="cap-lead-001"/>
                    <constraint firstItem="cv-000-001" firstAttribute="trailing" secondItem="lbl-cap-001" secondAttribute="trailing" constant="12" id="cap-trail-001"/>
                    <!--Location Label-->
                    <constraint firstItem="lbl-loc-001" firstAttribute="top" secondItem="lbl-cap-001" secondAttribute="bottom" constant="4" id="loc-top-001"/>
                    <constraint firstItem="lbl-loc-001" firstAttribute="leading" secondItem="cv-000-001" secondAttribute="leading" constant="12" id="loc-lead-001"/>
                    <constraint firstItem="cv-000-001" firstAttribute="trailing" secondItem="lbl-loc-001" secondAttribute="trailing" constant="12" id="loc-trail-001"/>
                    <!--Comments Button-->
                    <constraint firstItem="cmt-btn-001" firstAttribute="top" secondItem="lbl-usr-001" secondAttribute="bottom" constant="4" id="cmt-btn-top-001"/>
                    <constraint firstItem="cmt-btn-001" firstAttribute="leading" secondItem="cv-000-001" secondAttribute="leading" constant="12" id="cmt-btn-lead-001"/>
                    <!--Bottom anchor for automatic cell height-->
                    <constraint firstItem="cv-000-001" firstAttribute="bottom" secondItem="cmt-btn-001" secondAttribute="bottom" constant="12" id="bot-cmt-001"/>
                </constraints>
            </tableViewCellContentView>
            <connections>
                <outlet property="postImageView" destination="piv-000-001" id="out-piv-001"/>
                <outlet property="usernameLabel" destination="lbl-usr-001" id="out-usr-001"/>
                <outlet property="captionLabel" destination="lbl-cap-001" id="out-cap-001"/>
                <outlet property="timestampLabel" destination="lbl-ts-001" id="out-ts-001"/>
                <outlet property="locationLabel" destination="lbl-loc-001" id="out-loc-001"/>
                <outlet property="blurView" destination="blur-view-001" id="out-blur-001"/>
                <outlet property="commentsButton" destination="cmt-btn-001" id="out-cmt-btn-001"/>
            </connections>
        </tableViewCell>
    </objects>
    <resources>
        <systemColor name="systemBackgroundColor">
            <color white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
        </systemColor>
    </resources>
</document>
